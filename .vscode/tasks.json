{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake --preset Debug",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": []
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build \"${workspaceFolder}/build/Debug\"",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "dependsOn": ["CMake Configure"]
        },
        {
            "label": "OpenOCD Flash",
            "type": "shell",
            "command": "openocd -f interface/stlink.cfg -f target/stm32f7x.cfg -c \"program build/Debug/Nucleo_First_Blink.elf verify reset exit\"",
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always" },
            "problemMatcher": []
        },
        {
            "label": "Build & Flash",
            "dependsOn": ["CMake Build", "OpenOCD Flash"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
